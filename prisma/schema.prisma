generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Inquiry {
  id         Int      @id @default(autoincrement())
  name       String
  phone      String
  email      String
  institution String
  service    String
  message    String
  status     String   @default("待联系")
  adminNote  String   @default("")
  createdAt  DateTime @default(now())
}

model Admin {
  id           Int    @id @default(autoincrement())
  username     String @unique
  passwordHash String
}
